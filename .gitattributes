# Default: detect text and force LF on checkout/checkin
* text=auto eol=lf

# Shell scripts: always LF (run on Linux containers)
*.sh text eol=lf

# PowerShell: CRLF (Windows native)
*.ps1 text eol=crlf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
*.pdf binary
*.docx binary
*.xlsx binary
*.zip binary
*.gz binary
*.tar binary
*.ttf binary
*.woff binary
*.woff2 binary
*.eot binary
*.otf binary
